<nav x-data="mobileNav()" class="border-b border-white/10 bg-brand-dark/80 backdrop-blur-md sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-lg font-bold">
      <span class="text-2xl">🍺</span>
      <span>Buy<span class="text-brand-beer">Me</span>Beer</span>
    </a>

    <div class="hidden items-center gap-2 sm:flex">
      <a href="/explore" class="btn-ghost">Explore</a>
      <% if (sessionUser) { %>
        <a href="/dashboard" class="btn-ghost">Dashboard</a>
        <a href="/<%= sessionUser.handle %>" class="btn-ghost">My page</a>
        <form action="/logout" method="post">
          <button type="submit" class="btn-secondary text-xs">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn-ghost">Log in</a>
        <a href="/signup" class="btn-primary">Start for free</a>
      <% } %>
    </div>

    <button
      type="button"
      @click="toggle()"
      class="btn-ghost p-2 sm:hidden"
      :aria-expanded="open"
      aria-label="Toggle menu"
    >
      <svg x-show="!open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg x-show="open" x-cloak class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    @click.outside="close()"
    class="border-t border-white/10 bg-brand-dark px-4 py-4 sm:hidden"
  >
    <div class="flex flex-col gap-2">
      <a href="/explore" @click="close()" class="btn-ghost justify-start">Explore</a>
      <% if (sessionUser) { %>
        <a href="/dashboard" @click="close()" class="btn-ghost justify-start">Dashboard</a>
        <a href="/<%= sessionUser.handle %>" @click="close()" class="btn-ghost justify-start">My page</a>
        <form action="/logout" method="post">
          <button type="submit" class="btn-secondary w-full text-xs">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" @click="close()" class="btn-ghost justify-start">Log in</a>
        <a href="/signup" @click="close()" class="btn-primary justify-center">Start for free</a>
      <% } %>
    </div>
  </div>
</nav>

<% if (typeof flash !== "undefined" && flash) { %>
  <div
    x-data="flashMessage()"
    x-show="visible"
    x-transition:enter="transition ease-out duration-400"
    x-transition:enter-start="opacity-0 -translate-y-3 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-300"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 -translate-y-2 scale-95"
    class="mx-auto w-full max-w-3xl px-4 pt-4"
  >
    <div class="<%= flash.type === 'success' ? 'flash-success' : flash.type === 'error' ? 'flash-error' : 'flash-info' %> flex items-start justify-between gap-3">
      <span><%= flash.message %></span>
      <button type="button" @click="visible = false" class="text-white/50 hover:text-white" aria-label="Dismiss">×</button>
    </div>
  </div>
<% } %>
