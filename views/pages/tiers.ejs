<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'tiers', user }) %>

<div class="mx-auto max-w-2xl" x-data="confirmDelete()">
  <header class="page-header">
    <h1 class="page-title">Support tiers</h1>
    <p class="page-subtitle">Monthly subscriptions & one-time support tiers.</p>
  </header>

  <div class="mt-8 space-y-3">
    <% tiers.forEach(function(tier, i) { %>
      <div class="card animate-fade-in-up" style="animation-delay: <%= Math.min(i * 80 + 200, 700) %>ms">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="font-semibold"><%= tier.name %></p>
            <p class="text-brand-beer"><%= formatMoney(tier.price) %><%= tier.billingInterval === 'month' ? '/mo' : '' %></p>
            <% if (tier.description) { %><p class="text-sm text-muted"><%= tier.description %></p><% } %>
          </div>
          <button type="button" @click='ask("<%= tier.id %>", <%- JSON.stringify(tier.name) %>)' class="btn-ghost text-red-400 text-xs">Delete</button>
          <form id="delete-tier-<%= tier.id %>" action="/dashboard/tiers/<%= tier.id %>/delete" method="post" class="hidden"></form>
        </div>
      </div>
    <% }) %>
  </div>

  <div
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="modal-backdrop"
    @keydown.escape.window="cancel()"
  >
    <div
      x-show="open"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 scale-90 translate-y-4"
      x-transition:enter-end="opacity-100 scale-100 translate-y-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      @click.outside="cancel()"
      class="card-static max-w-sm w-full"
    >
      <h2 class="font-semibold">Delete tier?</h2>
      <p class="mt-2 text-sm text-muted">Remove <span x-text="tierName" class="font-medium text-app-text"></span> from your page?</p>
      <div class="mt-6 flex gap-3">
        <button type="button" @click="cancel()" class="btn-secondary flex-1">Cancel</button>
        <button type="button" @click="submit()" class="btn-primary flex-1 !bg-red-600 !shadow-red-600/25">Delete</button>
      </div>
    </div>
  </div>

  <form action="/dashboard/tiers" method="post" class="card animate-fade-in-up anim-delay-400 mt-8 space-y-4">
    <h2 class="font-semibold">Add tier</h2>
    <div>
      <label class="label" for="name">Name</label>
      <input class="input" id="name" name="name" required placeholder="Supporter" />
    </div>
    <div>
      <label class="label" for="priceEuros">Price (€)</label>
      <input class="input" type="number" id="priceEuros" name="priceEuros" value="5" min="1" max="500" step="0.5" />
    </div>
    <div>
      <label class="label" for="billingInterval">Billing</label>
      <select class="input" id="billingInterval" name="billingInterval">
        <option value="one_time">One-time payment</option>
        <option value="month">Monthly subscription</option>
      </select>
      <p class="mt-1 text-xs text-muted">Monthly requires Stripe in production.</p>
    </div>
    <div>
      <label class="label" for="description">Description</label>
      <input class="input" id="description" name="description" placeholder="What supporters get" />
    </div>
    <button type="submit" class="btn-primary">Save tier</button>
  </form>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
