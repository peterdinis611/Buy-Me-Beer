<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'overview', user }) %>

<script type="application/json" id="dashboard-live-config"><%- JSON.stringify({
  totalCents: stats.total,
  count: stats.count,
  coffeeCount: stats.coffeeCount,
  beerCount: stats.beerCount,
  membershipCount: stats.membershipCount,
  customCount: stats.customCount,
  shopCount: stats.shopCount || 0,
  goalAmount: user.goalAmount,
  recentSupport: stats.supports.slice(0, 20).map(function(s) {
    return {
      id: s.id,
      supporterName: s.supporterName,
      formattedAmount: formatMoney(s.amount),
      product: s.product,
      message: s.message || '',
      emoji: s.product === 'coffee' ? '☕' : s.product === 'beer' ? '🍺' : s.product === 'membership' ? '⭐' : s.product === 'shop' ? '🛍️' : '💝',
      isNew: false,
      dateLabel: new Date(s.createdAt).toLocaleDateString()
    }
  })
}) %></script>

<script type="application/json" id="dashboard-share-config"><%- JSON.stringify({ profileUrl, handle: user.handle, displayName: user.displayName }) %></script>

<div x-data="dashboardLive(JSON.parse(document.getElementById('dashboard-live-config').textContent))">
  <div class="pointer-events-none fixed bottom-4 right-4 z-50 flex flex-col gap-2 lg:bottom-8 lg:right-8" aria-live="polite">
    <template x-for="toast in toasts" :key="toast.id">
      <div
        x-show="toast.visible"
        x-transition
        class="sse-toast pointer-events-auto"
      >
        <p class="text-xs uppercase tracking-wide text-muted">New support!</p>
        <p class="mt-1 font-semibold"><span x-text="toast.supporterName"></span> <span x-text="toast.emoji"></span></p>
        <p class="text-accent" x-text="toast.formattedAmount"></p>
      </div>
    </template>
  </div>

  <header class="page-header flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm text-muted">Creator dashboard</p>
      <h1 class="page-title">Hey, <%= user.displayName %> 👋</h1>
      <p class="page-subtitle">Live overview of your tips, members, and supporters.</p>
    </div>
    <a href="/dashboard/analytics" class="btn-secondary shrink-0 text-sm">View analytics →</a>
  </header>

  <% if (typeof emailUnverified !== 'undefined' && emailUnverified) { %>
    <div class="flash-info mb-6 text-sm">
      Verify your email in <a href="/dashboard/security" class="underline">Security settings</a>.
    </div>
  <% } %>

  <div class="grid gap-4 lg:grid-cols-3 lg:gap-6">
    <div class="stat-hero stat-hero-primary lg:col-span-2 animate-fade-in-up">
      <p class="stat-hero-label">Total earned</p>
      <p
        class="mt-2 font-display text-4xl font-bold text-accent lg:text-5xl"
        :class="totalPulse && 'animate-stat-pop'"
        x-text="totalFormatted"
      ></p>
      <p class="stat-hero-meta mt-3">
        <span :class="countPulse && 'text-app-text'" x-text="count"></span> supporters · live updates via SSE
      </p>
    </div>

    <div class="stat-hero animate-fade-in-up anim-delay-100" x-data="shareKit(JSON.parse(document.getElementById('dashboard-share-config').textContent))">
      <p class="text-xs uppercase tracking-wide text-muted">Share kit</p>
      <div class="mt-3 flex items-center gap-4">
        <img src="/dashboard/qr.png" alt="QR" class="size-20 rounded-xl border border-app-line bg-white p-1.5" />
        <div class="min-w-0 flex-1">
          <p class="truncate font-mono text-xs text-accent"><%= profileUrl %></p>
          <div class="mt-2 flex flex-wrap gap-1.5">
            <button type="button" @click="copy(profileUrl)" class="btn-secondary px-3 py-1.5 text-xs">Copy</button>
            <button type="button" @click="copy(embedCode)" class="btn-secondary px-3 py-1.5 text-xs">Embed</button>
          </div>
        </div>
      </div>
      <p x-show="copied" x-cloak class="mt-2 text-xs text-accent">Copied!</p>
    </div>
  </div>

  <div class="mt-6 grid grid-cols-2 gap-3 lg:grid-cols-4 lg:gap-4">
    <div class="stat-pill animate-fade-in-up anim-delay-200">
      <span class="text-2xl">☕</span>
      <div>
        <p class="stat-pill-label">Coffees</p>
        <p class="stat-pill-value" :class="coffeePulse && 'animate-stat-pop'" x-text="coffeeCount"></p>
      </div>
    </div>
    <div class="stat-pill animate-fade-in-up anim-delay-300">
      <span class="text-2xl">🍺</span>
      <div>
        <p class="stat-pill-label">Beers</p>
        <p class="stat-pill-value" :class="beerPulse && 'animate-stat-pop'" x-text="beerCount"></p>
      </div>
    </div>
    <div class="stat-pill animate-fade-in-up anim-delay-400">
      <span class="text-2xl">⭐</span>
      <div>
        <p class="stat-pill-label">Tiers</p>
        <p class="stat-pill-value" x-text="membershipCount"></p>
      </div>
    </div>
    <div class="stat-pill animate-fade-in-up anim-delay-500">
      <span class="text-2xl">💝</span>
      <div>
        <p class="stat-pill-label">Custom</p>
        <p class="stat-pill-value" x-text="customCount"></p>
      </div>
    </div>
  </div>

  <% if (user.goalAmount > 0) { %>
    <div class="card-static mt-6 animate-fade-in-up anim-delay-500" :class="goalPulse && 'ring-1 ring-brand-beer/30'">
      <div class="flex justify-between text-sm">
        <span class="text-muted"><%= user.goalTitle || 'Funding goal' %></span>
        <span class="font-medium text-accent"><span x-text="totalFormatted"></span> / <%= formatMoney(user.goalAmount) %></span>
      </div>
      <div class="progress-track mt-3 h-2.5">
        <div class="h-full rounded-full bg-brand-beer transition-all duration-700" :style="'width:' + goalProgress + '%'"></div>
      </div>
      <p class="mt-2 text-xs text-muted"><%= goalProgress %>% of goal</p>
    </div>
  <% } %>

  <div class="mt-8 grid gap-6 xl:grid-cols-3">
    <section class="xl:col-span-2 animate-fade-in-up anim-delay-600">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-display text-lg font-semibold text-app-text">Recent support</h2>
        <span class="text-xs text-muted">Live</span>
      </div>

      <div x-show="showEmpty" class="card-static py-12 text-center text-muted">
        <p class="animate-float text-4xl">🍻</p>
        <p class="mt-3 font-medium text-app-text">No tips yet</p>
        <p class="mt-1 text-sm">Share your link to get your first supporter.</p>
      </div>

      <div x-show="!showEmpty" class="space-y-2">
        <template x-for="item in recentSupport" :key="item.id">
          <div
            class="card-static flex flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:justify-between"
            :class="item.isNew && 'sse-new-row'"
          >
            <div class="flex items-start gap-3">
              <span class="mt-0.5 text-lg" x-text="item.emoji"></span>
              <div>
                <p class="font-medium text-app-text">
                  <span x-text="item.supporterName"></span>
                  <span class="ml-2 text-accent" x-text="item.formattedAmount"></span>
                </p>
                <p x-show="item.message" class="mt-0.5 text-sm text-muted" x-text="item.message"></p>
              </div>
            </div>
            <time class="shrink-0 text-xs text-muted" x-text="item.isNew ? 'Just now' : item.dateLabel"></time>
          </div>
        </template>
      </div>
    </section>

    <section class="animate-fade-in-up anim-delay-700">
      <h2 class="mb-4 font-display text-lg font-semibold text-app-text">Quick actions</h2>
      <div class="grid gap-2">
        <a href="/dashboard/posts" class="stat-pill hover:border-brand-beer/20">
          <span class="text-xl">📝</span>
          <div><p class="font-medium text-app-text">New post</p><p class="text-xs text-muted">Share an update</p></div>
        </a>
        <a href="/dashboard/tiers" class="stat-pill hover:border-brand-beer/20">
          <span class="text-xl">⭐</span>
          <div><p class="font-medium text-app-text">Manage tiers</p><p class="text-xs text-muted">Memberships</p></div>
        </a>
        <a href="/dashboard/settings" class="stat-pill hover:border-brand-beer/20">
          <span class="text-xl">⚙️</span>
          <div><p class="font-medium text-app-text">Edit profile</p><p class="text-xs text-muted">Branding & prices</p></div>
        </a>
      </div>
    </section>
  </div>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
