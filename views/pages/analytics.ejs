<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'analytics', user }) %>

<div
  class="mx-auto max-w-5xl"
  x-data="revenueChart(<%- JSON.stringify({ chart, chartMax, days }) %>)"
>
  <header class="page-header flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="page-title">Analytics</h1>
      <p class="page-subtitle">Revenue overview and CSV export.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/dashboard/analytics?days=30" class="<%= days === 30 ? 'btn-primary' : 'btn-secondary' %> text-sm">30 days</a>
      <a href="/dashboard/analytics?days=90" class="<%= days === 90 ? 'btn-primary' : 'btn-secondary' %> text-sm">90 days</a>
      <a href="/dashboard/analytics/export.csv?days=<%= days %>" class="btn-secondary text-sm">Export CSV</a>
    </div>
  </header>

  <div class="grid gap-4 sm:grid-cols-2">
    <div class="stat-hero stat-hero-primary">
      <p class="stat-hero-label">Period total</p>
      <p class="mt-2 font-display text-3xl font-bold text-accent"><%= formatMoney(monthTotal) %></p>
    </div>
    <div class="stat-hero">
      <p class="stat-hero-label">Supports</p>
      <p class="mt-2 font-display text-3xl font-bold text-app-text"><%= monthCount %></p>
    </div>
  </div>

  <div class="card-static mt-6">
    <p class="font-medium text-app-text">Daily revenue</p>
    <div class="mt-6 flex h-52 items-end gap-1 overflow-x-auto pb-2">
      <template x-for="bar in chart" :key="bar.date">
        <div class="flex min-w-[12px] flex-1 flex-col items-center justify-end gap-2">
          <div
            class="w-full min-h-[4px] rounded-t bg-brand-beer/80 transition-all duration-500 hover:bg-brand-beer"
            :style="`height:${barHeight(bar.total)}%`"
            :title="bar.date"
          ></div>
          <span class="hidden text-[10px] text-muted sm:block" x-text="bar.date.slice(5)"></span>
        </div>
      </template>
    </div>
  </div>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
