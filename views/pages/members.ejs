<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'members', user }) %>

<div class="mx-auto max-w-3xl">
  <header class="page-header">
    <h1 class="page-title">Members</h1>
    <p class="page-subtitle">Active monthly and tier supporters.</p>
  </header>

  <% if (members.length === 0) { %>
    <div class="card-static py-12 text-center text-white/50">
      <p class="text-4xl">👥</p>
      <p class="mt-2">No active members yet.</p>
      <a href="/dashboard/tiers" class="btn-secondary mt-4 inline-flex">Set up tiers</a>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% members.forEach(function(m) { %>
        <div class="card-static flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="font-medium"><%= m.supporterName %></p>
            <p class="text-sm text-white/50"><%= tierMap[m.tierId] || 'Tier' %> · <%= m.supporterEmail || 'No email' %></p>
          </div>
          <div class="text-right text-sm">
            <span class="text-brand-beer"><%= m.status %></span>
            <% if (m.currentPeriodEnd) { %>
              <p class="text-white/40">until <%= new Date(m.currentPeriodEnd).toLocaleDateString() %></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
