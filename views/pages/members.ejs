<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto max-w-3xl px-4 py-10">
  <h1 class="font-display text-3xl font-bold">Members</h1>
  <p class="mt-2 text-white/50">Active monthly and tier supporters.</p>

  <% if (members.length === 0) { %>
    <div class="card mt-8 text-center text-white/50">
      <p class="text-4xl">👥</p>
      <p class="mt-2">No active members yet.</p>
      <a href="/dashboard/tiers" class="btn-secondary mt-4 inline-flex">Set up tiers</a>
    </div>
  <% } else { %>
    <div class="mt-8 space-y-3">
      <% members.forEach(function(m) { %>
        <div class="card flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="font-medium"><%= m.supporterName %></p>
            <p class="text-sm text-white/50"><%= tierMap[m.tierId] || 'Tier' %> · <%= m.supporterEmail || 'No email' %></p>
          </div>
          <div class="text-right text-sm">
            <span class="text-brand-beer"><%= m.status %></span>
            <% if (m.currentPeriodEnd) { %>
              <p class="text-white/40">until <%= new Date(m.currentPeriodEnd).toLocaleDateString() %></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <a href="/dashboard" class="btn-ghost mt-8 inline-flex">← Dashboard</a>
</div>

<%- include('../partials/footer') %>
