<%
  const isLight = creator.theme === 'minimal';
  const creatorTheme = isLight ? 'light' : 'dark';
  const bodyClass = creator.theme === 'dark'
    ? 'min-h-screen bg-gradient-to-b from-stone-900 to-[#140e0a] font-body text-white antialiased flex flex-col'
    : creator.theme === 'minimal'
      ? 'min-h-screen bg-[#f5f5f4] font-body text-gray-900 antialiased flex flex-col'
      : 'min-h-screen bg-gradient-to-b from-[#1c1917] to-[#140e0a] font-body text-white antialiased flex flex-col';
  const hasCover = !!creator.coverImageUrl;
  const hasPosts = typeof posts !== 'undefined' && posts.length > 0;
  const hasLeaderboard = typeof leaderboard !== 'undefined' && leaderboard.length > 0;
  const hasWall = typeof publicMessages !== 'undefined' && publicMessages.length > 0;
  const hasCommunity = hasPosts || hasLeaderboard || hasWall;
  const hasTiers = typeof tiers !== 'undefined' && tiers.length > 0;
%>

<%- include('../partials/head', { title, bodyClass, ogDescription, profileUrl, ogImage: creator.avatarUrl, inlineStyle: typeof brandingStyle !== 'undefined' ? brandingStyle : '' }) %>

<header class="creator-site-header" data-creator-theme="<%= creatorTheme %>">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="text-sm font-medium creator-muted hover:opacity-80">🍺 Buy Me Beer</a>
    <% if (sessionUser && sessionUser.handle === creator.handle) { %>
      <a href="/dashboard" class="text-sm creator-accent">Dashboard</a>
    <% } %>
  </div>
</header>

<%- include('../partials/flash') %>

<script type="application/json" id="creator-support-config"><%- JSON.stringify(supportConfig) %></script>

<div
  class="creator-page"
  data-creator-theme="<%= creatorTheme %>"
  x-data="creatorPage(JSON.parse(document.getElementById('creator-support-config').textContent))"
>
  <div class="creator-layout">
    <aside class="creator-sidebar animate-fade-in-up creator-surface overflow-hidden p-0 text-left lg:sticky lg:top-4">
      <% if (hasCover) { %>
        <img src="<%= creator.coverImageUrl %>" alt="" class="h-24 w-full object-cover sm:h-28" />
      <% } %>
      <div class="creator-sidebar-body">
        <div class="creator-profile-row">
          <img
            src="<%= creator.avatarUrl %>"
            alt="<%= creator.displayName %> profile photo"
            class="avatar-ring size-16 shrink-0 rounded-full border-2 <%= isLight ? 'border-white shadow-md' : 'border-white/20' %> object-cover"
            onerror="this.src='https://api.dicebear.com/7.x/avataaars/svg?seed=<%= creator.handle %>'"
          />
          <div class="min-w-0">
            <h1 class="creator-heading truncate text-lg leading-tight sm:text-xl"><%= creator.displayName %></h1>
            <p class="text-xs creator-muted">@<%= creator.handle %></p>
          </div>
        </div>

        <% if (creator.bio) { %>
          <p class="creator-text mt-3 line-clamp-3 text-sm leading-relaxed"><%= creator.bio %></p>
        <% } %>

        <% if (creator.website || creator.twitter || creator.github) { %>
          <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs">
            <% if (creator.website) { %><a href="<%= creator.website %>" target="_blank" rel="noopener" class="creator-accent hover:underline">Website</a><% } %>
            <% if (creator.twitter) { %><a href="https://twitter.com/<%= creator.twitter %>" target="_blank" rel="noopener" class="creator-accent hover:underline">@<%= creator.twitter %></a><% } %>
            <% if (creator.github) { %><a href="https://github.com/<%= creator.github %>" target="_blank" rel="noopener" class="creator-accent hover:underline">GitHub</a><% } %>
          </div>
        <% } %>

        <% if (creator.goalAmount > 0 || stats.count > 0) { %>
          <div class="creator-divider mt-4 space-y-3 border-t pt-4">
            <% if (creator.goalAmount > 0) { %>
              <div>
                <div class="flex justify-between text-xs creator-muted">
                  <span class="truncate pr-2"><%= creator.goalTitle || 'Goal' %></span>
                  <span class="shrink-0"><%= formatMoney(stats.total) %> / <%= formatMoney(creator.goalAmount) %></span>
                </div>
                <div class="creator-progress-track mt-1.5 h-1.5 overflow-hidden rounded-full">
                  <div class="h-full rounded-full bg-brand-beer transition-all duration-700" style="width: <%= goalProgress %>%"></div>
                </div>
              </div>
            <% } %>
            <% if (stats.count > 0) { %>
              <p class="text-xs creator-muted">
                <%= stats.count %> supporter<%= stats.count === 1 ? '' : 's' %> · <%= formatMoney(stats.total) %>
              </p>
            <% } %>
          </div>
        <% } %>
      </div>
    </aside>

    <div class="creator-main animate-fade-in-up anim-delay-100">
      <nav class="creator-tabs" aria-label="Creator page sections">
        <button
          type="button"
          class="creator-tab"
          :class="tab === 'support' && 'creator-tab--active'"
          @click="setTab('support')"
        >
          Support
        </button>
        <% if (hasCommunity) { %>
          <button
            type="button"
            class="creator-tab"
            :class="tab === 'community' && 'creator-tab--active'"
            @click="setTab('community')"
          >
            Community
          </button>
        <% } %>
        <button
          type="button"
          class="creator-tab"
          :class="tab === 'commission' && 'creator-tab--active'"
          @click="setTab('commission')"
        >
          Commission
        </button>
      </nav>

      <div class="creator-panel-area">
        <div class="creator-panel-scroll space-y-4" :class="tab !== 'support' && 'hidden'">
          <form
            action="/<%= creator.handle %>/support"
            method="post"
            @submit="onSubmit()"
            class="space-y-4"
          >
            <input type="hidden" name="product" :value="product" />
            <input type="hidden" name="membershipTierId" :value="membershipTierId" />

            <section class="creator-panel creator-surface">
              <p class="creator-text mb-3 text-sm font-medium">Choose amount</p>
              <div class="creator-tip-grid">
                <button
                  type="button"
                  @click="selectBeer()"
                  class="creator-tip"
                  :class="product === 'beer' && 'creator-tip--selected'"
                >
                  <span class="text-2xl">🍺</span>
                  <p class="mt-1 text-sm font-semibold leading-tight"><%= creator.beerLabel %></p>
                  <p class="mt-0.5 text-base font-bold creator-accent"><%= formatMoney(creator.beerPrice) %></p>
                </button>
                <div class="creator-tip" :class="product === 'custom' && 'creator-tip--selected'">
                  <p class="text-xs font-medium creator-text">Custom €</p>
                  <input
                    x-model="customAmount"
                    @focus="selectCustom()"
                    class="creator-input mt-1 px-2 py-1.5 text-sm"
                    type="number"
                    name="customAmount"
                    min="1"
                    max="1000"
                    step="0.5"
                    placeholder="5.00"
                  />
                </div>
              </div>
            </section>

            <% if (hasTiers) { %>
              <section class="creator-panel creator-surface">
                <p class="creator-text mb-2 text-sm font-medium">Membership tiers</p>
                <div class="space-y-1.5">
                  <% tiers.forEach(function(tier) { %>
                    <button
                      type="button"
                      @click='selectTier("<%= tier.id %>")'
                      class="creator-tier-row"
                      :class="membershipTierId === '<%= tier.id %>' && 'creator-tier-row--selected'"
                    >
                      <div class="min-w-0">
                        <p class="creator-heading truncate text-sm"><%= tier.name %></p>
                        <p class="truncate text-xs creator-muted"><%= tier.billingInterval === 'month' ? 'Monthly' : 'One-time' %><% if (tier.description) { %> · <%= tier.description %><% } %></p>
                      </div>
                      <span class="creator-accent shrink-0 text-sm font-bold"><%= tier.billingInterval === 'month' ? formatMoney(tier.price) + '/mo' : formatMoney(tier.price) %></span>
                    </button>
                  <% }) %>
                </div>
              </section>
            <% } %>

            <section x-show="hasSelection" x-cloak x-transition class="creator-panel creator-surface space-y-3">
              <div class="creator-divider flex items-center justify-between gap-3 border-b pb-3">
                <div class="min-w-0 text-left">
                  <p class="text-xs uppercase tracking-wide creator-muted">Selected</p>
                  <p class="creator-heading truncate text-sm" x-text="summaryLabel"></p>
                </div>
                <p class="creator-accent shrink-0 text-lg font-bold" x-text="summaryAmount"></p>
              </div>
              <div class="grid gap-2 sm:grid-cols-2">
                <input x-model="name" class="creator-input text-sm" type="text" name="name" placeholder="Your name" />
                <input x-model="email" class="creator-input text-sm" type="email" name="email" placeholder="Email (optional)" />
              </div>
              <textarea
                x-model="message"
                class="creator-input min-h-[64px] resize-y text-sm"
                name="message"
                maxlength="280"
                placeholder="Message (optional)…"
              ></textarea>
              <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs creator-text">
                <label class="flex cursor-pointer items-center gap-2">
                  <input type="hidden" name="isPublic" :value="isPublic ? 'true' : 'false'" />
                  <input type="checkbox" x-model="isPublic" class="size-3.5 rounded accent-brand-beer" />
                  Show on wall
                </label>
                <label class="flex cursor-pointer items-center gap-2">
                  <input type="hidden" name="isGift" :value="isGift ? 'true' : 'false'" />
                  <input type="checkbox" x-model="isGift" class="size-3.5 rounded accent-brand-beer" />
                  Gift 🎁
                </label>
              </div>
              <div x-show="isGift" x-cloak class="grid gap-2 sm:grid-cols-2">
                <input x-model="giftRecipientName" class="creator-input text-sm sm:col-span-2" type="text" name="giftRecipientName" placeholder="Recipient name" />
                <textarea x-model="giftMessage" class="creator-input min-h-[56px] resize-y text-sm sm:col-span-2" name="giftMessage" maxlength="280" placeholder="Gift message"></textarea>
              </div>
            </section>

            <button
              type="submit"
              class="creator-btn-primary"
              :disabled="!canSubmit"
              x-text="submitLabel"
            ></button>
            <% if (!stripeEnabled) { %>
              <p class="text-center text-xs creator-muted">Demo mode — no real charge</p>
            <% } else { %>
              <p class="text-center text-xs creator-muted">Secure checkout via Stripe</p>
            <% } %>
          </form>
        </div>

        <% if (hasCommunity) { %>
          <div class="creator-panel-scroll space-y-5 hidden" :class="tab === 'community' && '!block'">
            <% if (hasPosts) { %>
              <section class="creator-section">
                <div class="creator-section-head creator-divider border-b">
                  <h2 class="creator-section-title">Updates</h2>
                  <% if (!canViewMembersPosts) { %>
                    <form action="/<%= creator.handle %>/members/verify" method="post" class="flex w-full max-w-xs gap-2">
                      <input class="creator-input min-w-0 flex-1 text-sm" type="email" name="email" placeholder="Member email" required />
                      <button type="submit" class="creator-btn-secondary">Unlock</button>
                    </form>
                  <% } else if (memberEmail) { %>
                    <p class="text-xs creator-muted"><%= memberEmail %></p>
                  <% } %>
                </div>
                <div class="space-y-3">
                  <% posts.forEach(function(post) { %>
                    <article class="creator-panel creator-surface text-left">
                      <div class="flex items-start justify-between gap-2">
                        <h3 class="creator-heading text-sm"><%= post.title %></h3>
                        <% if (post.visibility === 'members') { %>
                          <span class="creator-accent shrink-0 rounded-full bg-brand-beer/15 px-2 py-0.5 text-[10px]">Members</span>
                        <% } %>
                      </div>
                      <% if (post.visibility === 'members' && !canViewMembersPosts) { %>
                        <p class="creator-muted mt-2 text-xs">Members-only — verify email to read.</p>
                      <% } else if (isPostBodyHtml(post.body)) { %>
                        <div class="post-content creator-text mt-2 line-clamp-4 text-sm"><%- sanitizePostBody(post.body) %></div>
                      <% } else { %>
                        <div class="creator-text prose-like mt-2 line-clamp-4 whitespace-pre-wrap text-sm"><%= post.body %></div>
                      <% } %>
                      <p class="creator-muted mt-2 text-[11px]"><%= new Date(post.createdAt).toLocaleDateString() %></p>
                    </article>
                  <% }) %>
                </div>
              </section>
            <% } %>

            <% if (hasLeaderboard) { %>
              <section class="creator-section">
                <div class="creator-section-head creator-divider border-b">
                  <h2 class="creator-section-title">Top supporters</h2>
                </div>
                <div class="space-y-1.5">
                  <% leaderboard.forEach(function(entry) { %>
                    <div class="creator-surface flex items-center justify-between rounded-xl border px-3 py-2 text-sm">
                      <div class="flex min-w-0 items-center gap-2">
                        <span><%= entry.badge || '⭐' %></span>
                        <div class="min-w-0">
                          <p class="creator-heading truncate text-sm"><%= entry.name %></p>
                          <p class="creator-muted text-[11px]"><%= entry.count %>×</p>
                        </div>
                      </div>
                      <p class="creator-accent shrink-0 font-bold"><%= formatMoney(entry.total) %></p>
                    </div>
                  <% }) %>
                </div>
              </section>
            <% } %>

            <% if (hasWall) { %>
              <section class="creator-section">
                <div class="creator-section-head creator-divider border-b">
                  <h2 class="creator-section-title">Supporter wall</h2>
                </div>
                <div class="space-y-2">
                  <% publicMessages.forEach(function(s) { %>
                    <div class="creator-panel creator-surface text-left">
                      <p class="creator-text text-xs">
                        <% if (s.isGift && s.giftRecipientName) { %>
                          <%= s.supporterName %> → <%= s.giftRecipientName %> · <%= formatMoney(s.amount) %>
                        <% } else { %>
                          <%= s.supporterName %> · <%= formatMoney(s.amount) %>
                        <% } %>
                      </p>
                      <p class="creator-text mt-1 line-clamp-2 text-sm italic">"<%= s.message %>"</p>
                    </div>
                  <% }) %>
                </div>
              </section>
            <% } %>
          </div>
        <% } %>

        <div class="creator-panel-scroll hidden" :class="tab === 'commission' && '!block'">
          <section class="creator-panel creator-surface">
            <h2 class="creator-section-title">Request a commission</h2>
            <p class="creator-muted mt-1 text-xs">Describe your project and budget.</p>
            <form action="/<%= creator.handle %>/commission" method="post" class="mt-4 space-y-3">
              <div class="grid gap-2 sm:grid-cols-2">
                <input class="creator-input text-sm" type="text" name="clientName" placeholder="Your name" required />
                <input class="creator-input text-sm" type="email" name="clientEmail" placeholder="Email (optional)" />
              </div>
              <input class="creator-input text-sm" type="text" name="title" placeholder="Project title" required />
              <textarea class="creator-input min-h-[80px] resize-y text-sm" name="description" placeholder="Describe the work…"></textarea>
              <div>
                <label class="creator-text text-xs">Budget (€)</label>
                <input class="creator-input mt-1 text-sm" type="number" name="priceEuros" min="5" max="5000" step="1" placeholder="50" required />
              </div>
              <button type="submit" class="creator-btn-primary py-2.5">Submit request</button>
            </form>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>

<footer class="creator-site-footer py-4 text-center text-[11px]" data-creator-theme="<%= creatorTheme %>">
  Powered by Buy Me Beer
</footer>

<script src="/js/app.js" defer></script>
</body>
</html>
