<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto flex min-h-[70vh] max-w-md items-center px-4 py-12">
  <div class="w-full">
    <h1 class="font-display text-3xl font-bold">Set new password</h1>
    <form action="/reset-password" method="post" class="mt-8 space-y-4">
      <input type="hidden" name="token" value="<%= token %>" />
      <div>
        <label class="label" for="password">New password</label>
        <input class="input" type="password" id="password" name="password" required minlength="8" />
      </div>
      <button type="submit" class="btn-primary w-full py-3">Update password</button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
