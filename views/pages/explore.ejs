<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto max-w-6xl px-4 py-12">
  <h1 class="animate-fade-in-up font-display text-3xl font-bold">Explore creators</h1>
  <p class="animate-fade-in-up anim-delay-100 mt-2 text-white/50">Discover pages to support.</p>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% creators.forEach(function(c, i) { %>
      <a
        href="/<%= c.handle %>"
        class="card group animate-fade-in-up"
        style="animation-delay: <%= Math.min(i * 80 + 150, 800) %>ms"
      >
        <div class="flex items-center gap-4">
          <img
            src="<%= c.avatarUrl %>"
            alt=""
            class="avatar-ring size-14 rounded-full border border-white/10 object-cover transition-transform duration-300 group-hover:scale-110"
          />
          <div class="min-w-0">
            <p class="truncate font-semibold transition-colors duration-200 group-hover:text-brand-beer"><%= c.displayName %></p>
            <p class="text-sm text-white/40">@<%= c.handle %></p>
          </div>
        </div>
        <% if (c.bio) { %>
          <p class="mt-3 line-clamp-2 text-sm text-white/55"><%= c.bio %></p>
        <% } %>
      </a>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
