<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto max-w-6xl px-4 py-12" x-data="exploreSearch()">
  <h1 class="animate-fade-in-up font-display text-3xl font-bold">Explore creators</h1>
  <p class="animate-fade-in-up anim-delay-100 mt-2 text-muted">Discover pages to support.</p>

  <div class="animate-fade-in-up anim-delay-200 relative mt-8 max-w-md">
    <input
      x-model="query"
      type="search"
      class="input pl-10"
      placeholder="Search by name or @handle…"
      aria-label="Search creators"
    />
    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-muted">🔍</span>
  </div>

  <% if (creators.length === 0) { %>
    <div class="card mt-10 text-center text-muted">
      <p class="text-4xl">🌱</p>
      <p class="mt-2">No creators yet — be the first!</p>
      <a href="/signup" class="btn-primary mt-4 inline-flex">Create your page</a>
    </div>
  <% } else { %>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% creators.forEach(function(c, i) { %>
        <a
          href="/<%= c.handle %>"
          x-show='matches(<%- JSON.stringify(c.displayName) %>, <%- JSON.stringify(c.handle) %>, <%- JSON.stringify(c.bio || "") %>)'
          x-transition
          class="card group animate-fade-in-up"
          style="animation-delay: <%= Math.min(i * 60 + 100, 600) %>ms"
        >
          <div class="flex items-center gap-4">
            <img
              src="<%= c.avatarUrl %>"
              alt="<%= c.displayName %>"
              class="avatar-ring size-14 rounded-full border-app-line object-cover group-hover:scale-110"
              onerror="this.src='https://api.dicebear.com/7.x/avataaars/svg?seed=<%= c.handle %>'"
            />
            <div class="min-w-0">
              <p class="truncate font-semibold transition-colors group-hover:text-brand-beer"><%= c.displayName %></p>
              <p class="text-sm text-muted">@<%= c.handle %></p>
            </div>
          </div>
          <% if (c.bio) { %>
            <p class="mt-3 line-clamp-2 text-sm text-muted"><%= c.bio %></p>
          <% } %>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
