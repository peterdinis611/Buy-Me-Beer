<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto flex min-h-[70vh] max-w-md items-center px-4 py-12">
  <div class="w-full">
    <h1 class="font-display text-3xl font-bold">Forgot password?</h1>
    <p class="mt-2 text-muted">We'll send you a reset link.</p>
    <form action="/forgot-password" method="post" class="mt-8 space-y-4">
      <div>
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" required />
      </div>
      <button type="submit" class="btn-primary w-full py-3">Send reset link</button>
    </form>
    <p class="mt-6 text-center text-sm text-muted">
      <a href="/login" class="text-brand-beer hover:underline">Back to login</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
