<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'settings', user }) %>

<div
  class="mx-auto max-w-2xl"
  x-data="settingsForm(<%- JSON.stringify({ bio: user.bio, coffeePriceEuros: coffeePriceEuros, beerPriceEuros: beerPriceEuros, goalEuros: goalEuros, primaryColor: user.primaryColor || '#F5A623' }) %>)"
>
  <header class="page-header">
    <h1 class="page-title">Profile settings</h1>
    <p class="page-subtitle">Customize your public creator page.</p>
  </header>

  <form action="/dashboard/settings" method="post" class="animate-fade-in-up anim-delay-200 mt-8 space-y-6">
    <div class="card space-y-4">
      <h2 class="font-semibold">Basic info</h2>
      <div>
        <label class="label" for="displayName">Display name</label>
        <input class="input" type="text" id="displayName" name="displayName" value="<%= user.displayName %>" required />
      </div>
      <div>
        <label class="label" for="handle">Username</label>
        <input class="input" type="text" id="handle" name="handle" value="<%= user.handle %>" required pattern="[a-zA-Z0-9_-]+" />
        <p class="mt-1.5 text-xs text-white/40">Changing your username breaks old links — update shared URLs after saving.</p>
      </div>
      <div>
        <label class="label" for="bio">Bio</label>
        <textarea x-model="bio" class="input min-h-[100px] resize-y" id="bio" name="bio" maxlength="500"></textarea>
        <p class="mt-1 text-right text-xs text-white/40"><span x-text="bioRemaining"></span> characters left</p>
      </div>
      <div>
        <label class="label" for="avatarUrl">Avatar URL</label>
        <input class="input" type="url" id="avatarUrl" name="avatarUrl" value="<%= user.avatarUrl %>" placeholder="https://..." />
      </div>
      <div>
        <label class="label" for="coverImageUrl">Cover image URL</label>
        <input class="input" type="url" id="coverImageUrl" name="coverImageUrl" value="<%= user.coverImageUrl %>" placeholder="https://..." />
      </div>
      <div>
        <label class="label" for="primaryColor">Brand color</label>
        <div class="flex items-center gap-3">
          <input x-model="primaryColor" class="input flex-1 font-mono uppercase" type="text" id="primaryColor" name="primaryColor" pattern="#[0-9A-Fa-f]{6}" value="<%= user.primaryColor || '#F5A623' %>" />
          <input x-model="primaryColor" type="color" class="size-11 cursor-pointer rounded-lg border border-white/10 bg-transparent" />
        </div>
      </div>
      <div>
        <label class="label" for="theme">Theme</label>
        <select class="input" id="theme" name="theme">
          <option value="warm" <%= user.theme === 'warm' ? 'selected' : '' %>>Warm — coffee & beer gradient</option>
          <option value="dark" <%= user.theme === 'dark' ? 'selected' : '' %>>Dark — minimal black</option>
          <option value="minimal" <%= user.theme === 'minimal' ? 'selected' : '' %>>Minimal — light & clean</option>
        </select>
        <p class="mt-1.5 text-xs text-white/40"><a href="/<%= user.handle %>" target="_blank" class="text-brand-beer hover:underline">Preview your page ↗</a></p>
      </div>
    </div>

    <div class="card space-y-4">
      <h2 class="font-semibold">Tip amounts</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="label" for="coffeeLabel">☕ Coffee label</label>
          <input class="input" type="text" id="coffeeLabel" name="coffeeLabel" value="<%= user.coffeeLabel %>" />
          <label class="label mt-3" for="coffeePriceEuros">Price (€)</label>
          <input x-model.number="coffeePriceEuros" class="input" type="number" id="coffeePriceEuros" name="coffeePriceEuros" min="1" max="1000" step="0.5" />
          <p class="mt-1 text-xs text-brand-beer" x-text="'Preview: ' + coffeePreview()"></p>
        </div>
        <div>
          <label class="label" for="beerLabel">🍺 Beer label</label>
          <input class="input" type="text" id="beerLabel" name="beerLabel" value="<%= user.beerLabel %>" />
          <label class="label mt-3" for="beerPriceEuros">Price (€)</label>
          <input x-model.number="beerPriceEuros" class="input" type="number" id="beerPriceEuros" name="beerPriceEuros" min="1" max="1000" step="0.5" />
          <p class="mt-1 text-xs text-brand-beer" x-text="'Preview: ' + beerPreview()"></p>
        </div>
      </div>
    </div>

    <div class="card space-y-4">
      <h2 class="font-semibold">Social links</h2>
      <div>
        <label class="label" for="website">Website</label>
        <input class="input" type="text" id="website" name="website" value="<%= user.website %>" placeholder="yoursite.com" />
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="label" for="twitter">Twitter / X</label>
          <input class="input" type="text" id="twitter" name="twitter" value="<%= user.twitter %>" placeholder="username" />
        </div>
        <div>
          <label class="label" for="github">GitHub</label>
          <input class="input" type="text" id="github" name="github" value="<%= user.github %>" placeholder="username" />
        </div>
      </div>
    </div>

    <div class="card space-y-4">
      <h2 class="font-semibold">Funding goal</h2>
      <div>
        <label class="label" for="goalTitle">Goal title</label>
        <input class="input" type="text" id="goalTitle" name="goalTitle" value="<%= user.goalTitle %>" placeholder="New camera gear" />
      </div>
      <div>
        <label class="label" for="goalEuros">Target (€, 0 = off)</label>
        <input x-model.number="goalEuros" class="input" type="number" id="goalEuros" name="goalEuros" min="0" step="1" />
        <p class="mt-1 text-xs text-brand-beer" x-text="'Preview: ' + goalPreview()"></p>
      </div>
    </div>

    <div class="card space-y-4">
      <h2 class="font-semibold">Thank-you email</h2>
      <div>
        <label class="label" for="thankYouMessage">Message to supporters (optional)</label>
        <textarea class="input min-h-[88px] resize-y" id="thankYouMessage" name="thankYouMessage" maxlength="500"><%= thankYouMessage %></textarea>
        <p class="mt-1 text-xs text-white/40">Sent by email after a tip (if supporter leaves their email).</p>
      </div>
    </div>

    <button type="submit" class="btn-primary w-full py-3">Save changes</button>
  </form>

  <div class="card mt-6 space-y-4">
    <h2 class="font-semibold">Upload images</h2>
    <form action="/dashboard/upload/avatar" method="post" enctype="multipart/form-data" class="flex flex-wrap items-end gap-2">
      <div class="flex-1">
        <label class="label">Avatar file</label>
        <input class="input text-sm" type="file" name="avatar" accept="image/*" required />
      </div>
      <button type="submit" class="btn-secondary text-sm">Upload avatar</button>
    </form>
    <form action="/dashboard/upload/cover" method="post" enctype="multipart/form-data" class="flex flex-wrap items-end gap-2">
      <div class="flex-1">
        <label class="label">Cover file</label>
        <input class="input text-sm" type="file" name="cover" accept="image/*" required />
      </div>
      <button type="submit" class="btn-secondary text-sm">Upload cover</button>
    </form>
  </div>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
