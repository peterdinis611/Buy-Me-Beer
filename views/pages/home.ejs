<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(245,166,35,0.15),_transparent_55%)] animate-fade-in"></div>
  <div class="mx-auto max-w-6xl px-4 py-20 text-center">
    <div class="mb-6 inline-flex animate-fade-in-down items-center gap-2 rounded-full border border-brand-beer/30 bg-brand-beer/10 px-4 py-1.5 text-sm text-brand-beer">
      <span class="animate-float inline-block">☕</span>
      Coffee or
      <span class="animate-float inline-block anim-delay-300">🍺</span>
      Beer — you choose
    </div>
    <h1 class="animate-fade-in-up font-display text-4xl font-bold leading-tight sm:text-6xl">
      Get supported doing<br />
      <span class="animate-shimmer bg-gradient-to-r from-brand-beer via-amber-200 to-brand-coffee bg-clip-text text-transparent text-shimmer">what you love</span>
    </h1>
    <p class="animate-fade-in-up anim-delay-200 mx-auto mt-6 max-w-2xl text-lg text-white/60">
      Create your page in minutes. Let fans buy you a coffee or a beer with a message — no complex setup.
    </p>
    <div class="animate-fade-in-up anim-delay-300 mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href="/signup" class="btn-primary px-8 py-3 text-base">Create your page</a>
      <a href="/demo" class="btn-secondary px-8 py-3 text-base">See demo →</a>
    </div>

    <div class="mx-auto mt-16 grid max-w-3xl gap-4 sm:grid-cols-3">
      <div class="card animate-fade-in-up anim-delay-400 text-left">
        <div class="mb-2 text-2xl transition-transform duration-300 hover:animate-wiggle">⚡</div>
        <h3 class="font-semibold">Setup in 2 min</h3>
        <p class="mt-1 text-sm text-white/50">Sign up, customize prices, share your link.</p>
      </div>
      <div class="card animate-fade-in-up anim-delay-500 text-left">
        <div class="mb-2 text-2xl">☕🍺</div>
        <h3 class="font-semibold">Coffee or Beer</h3>
        <p class="mt-1 text-sm text-white/50">Two preset tiers + custom amounts.</p>
      </div>
      <div class="card animate-fade-in-up anim-delay-600 text-left">
        <div class="mb-2 text-2xl">💳</div>
        <h3 class="font-semibold">Stripe ready</h3>
        <p class="mt-1 text-sm text-white/50">Demo mode works out of the box.</p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
