<%- include('../partials/head', { title }) %>
<%- include('../partials/dashboard-shell-open', { active: 'shop', user }) %>

<div class="mx-auto max-w-2xl">
  <header class="page-header">
    <h1 class="page-title">Shop / Extras</h1>
    <p class="page-subtitle">Sell digital products — PDFs, presets, templates, download links.</p>
  </header>

  <div class="space-y-3">
    <% items.forEach(function(item) { %>
      <div class="card-static">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-semibold"><%= item.name %></p>
            <p class="text-brand-beer"><%= formatMoney(item.price) %></p>
            <% if (item.description) { %><p class="mt-1 text-sm text-muted"><%= item.description %></p><% } %>
            <p class="mt-1 truncate text-xs text-muted"><%= item.src %></p>
          </div>
          <form action="/dashboard/shop/<%= item.id %>/delete" method="post">
            <button type="submit" class="btn-ghost text-xs text-red-400">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <form action="/dashboard/shop" method="post" class="card-static mt-8 space-y-4">
    <h2 class="font-semibold">Add product</h2>
    <div>
      <label class="label" for="name">Name</label>
      <input class="input" id="name" name="name" required placeholder="Lightroom Preset Pack" />
    </div>
    <div>
      <label class="label" for="description">Description</label>
      <input class="input" id="description" name="description" placeholder="10 premium presets" />
    </div>
    <div>
      <label class="label" for="src">Download URL</label>
      <input class="input" type="url" id="src" name="src" required placeholder="https://..." />
    </div>
    <div>
      <label class="label" for="priceEuros">Price (€)</label>
      <input class="input" type="number" id="priceEuros" name="priceEuros" value="5" min="1" max="500" step="0.5" />
    </div>
    <button type="submit" class="btn-primary">Save product</button>
  </form>
</div>

<%- include('../partials/dashboard-shell-close') %>
<%- include('../partials/dashboard-footer') %>
