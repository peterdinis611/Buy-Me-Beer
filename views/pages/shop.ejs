<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto max-w-2xl px-4 py-10">
  <h1 class="font-display text-3xl font-bold">Shop / Extras</h1>
  <p class="mt-2 text-white/50">Sell digital products — PDFs, presets, templates, download links.</p>

  <div class="mt-8 space-y-3">
    <% items.forEach(function(item) { %>
      <div class="card">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-semibold"><%= item.name %></p>
            <p class="text-brand-beer"><%= formatMoney(item.price) %></p>
            <% if (item.description) { %><p class="mt-1 text-sm text-white/50"><%= item.description %></p><% } %>
            <p class="mt-1 truncate text-xs text-white/35"><%= item.src %></p>
          </div>
          <form action="/dashboard/shop/<%= item.id %>/delete" method="post">
            <button type="submit" class="btn-ghost text-red-400 text-xs">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <form action="/dashboard/shop" method="post" class="card mt-8 space-y-4">
    <h2 class="font-semibold">Add product</h2>
    <div>
      <label class="label" for="name">Name</label>
      <input class="input" id="name" name="name" required placeholder="Lightroom Preset Pack" />
    </div>
    <div>
      <label class="label" for="description">Description</label>
      <input class="input" id="description" name="description" placeholder="10 premium presets" />
    </div>
    <div>
      <label class="label" for="src">Download URL</label>
      <input class="input" type="url" id="src" name="src" required placeholder="https://..." />
    </div>
    <div>
      <label class="label" for="priceEuros">Price (€)</label>
      <input class="input" type="number" id="priceEuros" name="priceEuros" value="5" min="1" max="500" step="0.5" />
    </div>
    <button type="submit" class="btn-primary">Save product</button>
  </form>

  <a href="/dashboard" class="btn-ghost mt-6 inline-flex">← Dashboard</a>
</div>

<%- include('../partials/footer') %>
