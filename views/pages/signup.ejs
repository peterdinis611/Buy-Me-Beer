<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto flex min-h-[70vh] max-w-md items-center px-4 py-12">
  <div class="w-full animate-fade-in-up">
    <h1 class="font-display text-3xl font-bold">Create your page</h1>
    <p class="mt-2 text-muted">Start accepting coffee & beer tips today.</p>

    <form action="/signup" method="post" class="animate-fade-in-up anim-delay-200 mt-8 space-y-4">
      <div class="animate-fade-in-up anim-delay-300">
        <label class="label" for="displayName">Display name</label>
        <input class="input" type="text" id="displayName" name="displayName" required placeholder="Alex Creator" />
      </div>
      <div class="animate-fade-in-up anim-delay-400">
        <label class="label" for="handle">Username (your link)</label>
        <div class="flex items-center gap-2">
          <span class="text-sm text-muted"><%= baseUrl %>/</span>
          <input class="input" type="text" id="handle" name="handle" required pattern="[a-zA-Z0-9_-]+" placeholder="alex" />
        </div>
      </div>
      <div class="animate-fade-in-up anim-delay-500">
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div class="animate-fade-in-up anim-delay-600">
        <label class="label" for="password">Password</label>
        <input class="input" type="password" id="password" name="password" required minlength="8" autocomplete="new-password" />
      </div>
      <button type="submit" class="btn-primary anim-delay-700 animate-fade-in-up w-full py-3">Create account</button>
    </form>

    <p class="animate-fade-in anim-delay-800 mt-6 text-center text-sm text-muted">
      Already have an account? <a href="/login" class="text-brand-beer hover:underline">Log in</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
