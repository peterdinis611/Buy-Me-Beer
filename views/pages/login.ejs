<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<div class="mx-auto flex min-h-[70vh] max-w-md items-center px-4 py-12">
  <div class="w-full animate-fade-in-up">
    <h1 class="font-display text-3xl font-bold">Welcome back</h1>
    <p class="mt-2 text-white/50 anim-delay-100 animate-fade-in">Log in to manage your creator page.</p>

    <form action="/login" method="post" class="animate-fade-in-up anim-delay-200 mt-8 space-y-4">
      <div>
        <label class="label" for="email">Email</label>
        <input class="input" type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div>
        <label class="label" for="password">Password</label>
        <input class="input" type="password" id="password" name="password" required autocomplete="current-password" />
        <p class="mt-2 text-right text-sm"><a href="/forgot-password" class="text-brand-beer hover:underline">Forgot password?</a></p>
      </div>
      <button type="submit" class="btn-primary w-full py-3">Log in</button>
    </form>

    <p class="animate-fade-in anim-delay-400 mt-6 text-center text-sm text-white/50">
      No account? <a href="/signup" class="text-brand-beer hover:underline">Sign up free</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
