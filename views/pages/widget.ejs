<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Support <%= creator.displayName %></title>
  <style>
    * { box-sizing: border-box; margin: 0; }
    body {
      font-family: system-ui, sans-serif;
      background: #140e0a;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }
    .card {
      max-width: 320px;
      width: 100%;
      text-align: center;
      padding: 24px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.1);
      background: rgba(255,255,255,.05);
    }
    img { width: 72px; height: 72px; border-radius: 9999px; margin: 0 auto 12px; }
    h1 { font-size: 1.125rem; margin-bottom: 4px; }
    p { color: rgba(255,255,255,.55); font-size: .875rem; margin-bottom: 16px; }
    a {
      display: block;
      padding: 12px 16px;
      border-radius: 12px;
      background: #F5A623;
      color: #140e0a;
      font-weight: 600;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="card">
    <img src="<%= creator.avatarUrl %>" alt="" />
    <h1><%= creator.displayName %></h1>
    <p>Support this creator</p>
    <a href="<%= profileUrl %>" target="_blank" rel="noopener">Open page →</a>
  </div>
</body>
</html>
